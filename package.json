{
  "name": "mcp-sdlc-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/krylovsentry/mcp-sdlc-tools.git"
  },
  "scripts": {
    "cli": "bun run src/cli.ts",
    "build:cli": "bun build --compile ./src/cli.ts --outfile ./dist/mcp-sdlc",
    "start": "bun run src/index.ts",
    "test": "bun test tests",
    "test:coverage": "bun test tests --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "coverage:check": "bun run src/checkCoverage.ts --min 80",
    "test:coverage:gate": "bun run test:coverage && bun run coverage:check",
    "typecheck": "tsc --noEmit",
    "lint:biome": "biome check .",
    "lint": "bun run typecheck",
    "smoke": "bun run src/smoke.ts",
    "generate:tests": "bun run src/generateTests.ts",
    "openapi:postman": "bun run src/openapiToPostman.cli.ts",
    "scaffold:testing": "bun run src/scaffoldTesting.ts",
    "test:playwright": "bun run --cwd testing/playwright test",
    "test:postman": "bun run --cwd testing/postman test",
    "model:test": "bun run src/modelTests.ts",
    "review:pr": "bun run src/reviewPr.ts",
    "dev:debug:agent": "cross-env DEV_TRACE=1 MODEL_TRACE=1 bun run src/index.ts",
    "dev:debug:smoke": "cross-env DEV_TRACE=1 MODEL_TRACE=1 bun run src/smoke.ts",
    "dev:debug:generate": "cross-env DEV_TRACE=1 MODEL_TRACE=1 bun run src/generateTests.ts",
    "dev:debug:model:test": "cross-env DEV_TRACE=1 MODEL_TRACE=1 bun run src/modelTests.ts",
    "dev:debug:review": "cross-env DEV_TRACE=1 MODEL_TRACE=1 bun run src/reviewPr.ts"
  },
  "dependencies": {
    "openapi-to-postmanv2": "^6.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.2.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.7.3"
  },
  "patchedDependencies": {
    "http-reasons@0.1.0": "patches/http-reasons@0.1.0.patch"
  }
}
